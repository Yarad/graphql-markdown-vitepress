{
  "name": "graphql-markdown-vitepress",
  "version": "0.1.0",
  "description": "VitePress integration for GraphQL schema documentation via GraphQL-Markdown",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./formatter": {
      "types": "./dist/formatter/index.d.ts",
      "import": "./dist/formatter/index.js",
      "require": "./dist/formatter/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "graphql",
    "vitepress",
    "documentation",
    "schema",
    "graphql-markdown"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yarad/graphql-markdown-vitepress"
  },
  "dependencies": {
    "@graphql-markdown/cli": "^0.7.0",
    "@graphql-markdown/types": "^1.10.1",
    "@graphql-markdown/utils": "^1.6.0",
    "@graphql-tools/json-file-loader": "^8.0.0",
    "gray-matter": "^4.0.3",
    "graphql": "^16.0.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0",
    "vitepress": ">=1.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitepress": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
