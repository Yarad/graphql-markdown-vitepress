{
  "name": "graphql-markdown-vitepress",
  "version": "0.0.7",
  "description": "VitePress integration for GraphQL schema documentation via GraphQL-Markdown",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./formatter": {
      "types": "./dist/formatter/index.d.ts",
      "import": "./dist/formatter/index.js",
      "require": "./dist/formatter/index.cjs"
    },
    "./theme": {
      "types": "./dist/client/theme.d.ts",
      "import": "./dist/client/theme.js",
      "require": "./dist/client/theme.cjs"
    },
    "./client": {
      "types": "./dist/client/lazy-fields.d.ts",
      "import": "./dist/client/lazy-fields.js",
      "require": "./dist/client/lazy-fields.cjs"
    },
    "./style.css": "./src/client/style.css"
  },
  "files": [
    "dist",
    "src/client/style.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"*.{json,js,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\" \"*.{json,js,md}\"",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "graphql",
    "vitepress",
    "documentation",
    "schema",
    "graphql-markdown"
  ],
  "author": "Andrei Zhlobich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yarad/graphql-markdown-vitepress.git"
  },
  "dependencies": {
    "@graphql-markdown/cli": "^0.7.0",
    "@graphql-markdown/types": "^1.10.1",
    "@graphql-markdown/utils": "^1.6.0",
    "@graphql-tools/graphql-file-loader": "^8.0.0",
    "@graphql-tools/json-file-loader": "^8.0.0",
    "graphql": "^16.0.0",
    "gray-matter": "^4.0.3"
  },
  "peerDependencies": {
    "vite": ">=5.0.0",
    "vitepress": ">=1.0.0",
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^5.0.0",
    "vitepress": "^1.0.0",
    "vitest": "^4.1.0",
    "vue": "^3.5.30"
  },
  "engines": {
    "node": ">=18"
  }
}
